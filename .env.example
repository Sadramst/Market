# Appilico Market — Production Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_USER=appilico_user
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=appilico_market;Username=appilico_user;Password=CHANGE_ME_TO_SECURE_PASSWORD

# JWT Authentication
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_OF_AT_LEAST_64_CHARS

# Domain (used by certbot)
DOMAIN=appilico.com.au
