{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "api.appilico.com.au,localhost,127.0.0.1,149.28.166.75",
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "appilico-market-api",
    "Audience": "appilico-market-clients",
    "ExpiryMinutes": "60"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://beauty.appilico.com.au",
      "https://service.appilico.com.au",
      "https://admin.appilico.com.au"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/appilico/api-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Forwarded-For",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "post:/api/auth/*",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/reviews",
        "Period": "1h",
        "Limit": 10
      }
    ]
  }
}
